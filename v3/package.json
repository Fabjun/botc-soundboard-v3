{
  "name": "v3",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "cd .. && husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test --project=smoke --project=smoke-webkit --project=full",
    "test:e2e:smoke": "playwright test --project=smoke --project=smoke-webkit",
    "test:e2e:full": "playwright test --project=full",
    "test:e2e:mobile": "playwright test --project=mobile --project=mobile-chromium",
    "test:e2e:all": "playwright test --project=smoke --project=smoke-webkit --project=full --project=mobile --project=mobile-chromium",
    "test:e2e:visual": "playwright test --project=visual",
    "test:e2e:update-snapshots": "playwright test --project=visual --update-snapshots",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "size": "size-limit",
    "sync:adr": "tsx ../scripts/sync-adr-index.ts",
    "sync:classes": "tsx ../scripts/sync-sb-classes-inventory.ts",
    "sync:tokens": "tsx ../scripts/sync-tokens-inventory.ts",
    "sync:docs": "npm run sync:adr && npm run sync:classes && npm run sync:tokens",
    "link:check": "find .. -name '*.md' -not -path '*/node_modules/*' | xargs markdown-link-check --config .markdown-link-check.json --quiet",
    "audit:inline-styles": "NODE_PATH=./node_modules tsx ../scripts/audit-inline-styles.ts"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@preact/signals": "^2.9.1",
    "idb": "^8.0.3",
    "preact": "^10.29.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@preact/preset-vite": "^2.10.5",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "size-limit": "^12.1.0",
    "markdown-link-check": "^3.13.7",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
