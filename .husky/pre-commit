#!/bin/sh
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT/v3" || exit 1

echo "📚 Pre-commit: syncing auto-generated docs..."
npm run sync:docs || {
  printf '\n❌ sync:docs failed — Commit abgebrochen.\n'
  printf '   Generator-Fehler oben beheben und erneut git commit.\n\n'
  exit 1
}
git -C "$ROOT" add docs/architecture/README.md DESIGN_SYSTEM.md
echo "✅ Docs synced and staged."

echo "🔨 Pre-commit: running build check in v3/..."
npm run build || {
  printf '\n❌ Build failed — Commit abgebrochen.\n'
  printf '   Fehler beheben und dann erneut git commit ausführen.\n\n'
  exit 1
}
echo "✅ Build passed."

echo "🎨 Pre-commit: running lint-staged (format + lint on staged files)..."
npx lint-staged || {
  printf '\n❌ lint-staged failed — Commit abgebrochen.\n'
  printf '   Fehler oben beheben, Dateien erneut stagen, dann git commit.\n\n'
  exit 1
}
echo "✅ lint-staged passed."

echo "🧪 Pre-commit: running unit tests in v3/..."
npm run test || {
  printf '\n❌ Unit tests failed — Commit abgebrochen.\n'
  printf '   Tests fixen und dann erneut git commit ausführen.\n\n'
  exit 1
}
echo "✅ Unit tests passed."

echo "🎭 Pre-commit: running smoke E2E tests..."
npm run test:e2e:smoke || {
  printf '\n❌ Smoke E2E tests failed — Commit abgebrochen.\n'
  printf '   Playwright-Report unter v3/playwright-report/ für Details.\n'
  printf '   Tests fixen und dann erneut git commit ausführen.\n\n'
  exit 1
}
echo "✅ Smoke E2E passed."

echo "🔗 Pre-commit: checking markdown link integrity..."
npm run link:check || {
  printf '\n❌ Link check failed — Commit abgebrochen.\n'
  printf '   Tote interne Links oben fixen und erneut git commit.\n\n'
  exit 1
}
echo "✅ Link check passed — Commit wird fortgesetzt."

# ── Non-blocking BACKLOG drift reminder ──────────────────────────────────────
BACKLOG_STAGED=$(git -C "$ROOT" diff --cached --name-only 2>/dev/null | grep "^BACKLOG.md$" || true)
LAST_BACKLOG=$(git -C "$ROOT" log -1 --format="%H" -- BACKLOG.md 2>/dev/null)
if [ -z "$BACKLOG_STAGED" ] && [ -n "$LAST_BACKLOG" ]; then
  COMMITS_SINCE=$(git -C "$ROOT" rev-list --count "$LAST_BACKLOG"..HEAD 2>/dev/null || echo "0")
  BACKLOG_THRESHOLD=10
  if [ "$COMMITS_SINCE" -ge "$BACKLOG_THRESHOLD" ]; then
    printf '\n💡 BACKLOG reminder: BACKLOG.md was last updated %s commits ago.\n' "$COMMITS_SINCE"
    printf '   Consider whether recent work added deferred items or closed existing ones.\n'
    printf '   (Reminder only — commit proceeds.)\n\n'
  fi
fi
